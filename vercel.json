{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/shipping/cost",
      "dest": "/api/shipping/cost.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
